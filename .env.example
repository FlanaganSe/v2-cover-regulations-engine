# PostGIS (used by docker-compose)
POSTGRES_DB=regulation_engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@db/regulation_engine
OPENAI_API_KEY=            # Required for M4+, optional for M1
MARTIN_URL=http://martin:3000

# Martin (libpq format)
MARTIN_DATABASE_URL=postgres://postgres:postgres@db/regulation_engine
