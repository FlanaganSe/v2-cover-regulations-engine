# PostGIS (used by docker-compose)
POSTGRES_DB=regulation_engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@db/regulation_engine
OPENAI_API_KEY=            # Optional — empty = deterministic fallback only
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
MARTIN_URL=http://martin:3000

# Martin (libpq format)
MARTIN_DATABASE_URL=postgres://postgres:postgres@db/regulation_engine

# Frontend (Vite build-time — set in frontend/.env.local or pass as build args)
# VITE_API_URL=http://localhost:8000
# VITE_MARTIN_URL=http://localhost:3001
